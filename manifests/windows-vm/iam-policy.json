{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowListBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::ocpctl-binaries"
      ],
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "windows-images/*"
          ]
        }
      }
    },
    {
      "Sid": "AllowGetWindowsImage",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": [
        "arn:aws:s3:::ocpctl-binaries/windows-images/*"
      ]
    }
  ]
}
