[Unit]
Description=OCPCTL Worker
After=network.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
User=ocpctl
WorkingDirectory=/opt/ocpctl
EnvironmentFile=/etc/ocpctl/worker.env

# Ensure installer binaries are available before starting (runs as root with + prefix)
ExecStartPre=+/opt/ocpctl/scripts/ensure-installers.sh

ExecStart=/opt/ocpctl/current/ocpctl-worker
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=ocpctl-worker

# Resource limits
LimitNOFILE=65536
LimitNPROC=4096

# Security
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
