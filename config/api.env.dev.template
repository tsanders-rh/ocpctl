# Dev Environment API Configuration
# Copy this file to api.env.dev and fill in the values

# Database - DEV ENVIRONMENT
# Option 1: Separate dev RDS instance
DATABASE_URL=postgresql://ocpctl_dev_user:CHANGE_ME@ocpctl-dev-db.xxx.rds.amazonaws.com:5432/ocpctl_dev?sslmode=require
# Option 2: Shared RDS with separate database
# DATABASE_URL=postgresql://ocpctl_dev_user:CHANGE_ME@ocpctl-db.xxx.rds.amazonaws.com:5432/ocpctl_dev?sslmode=require

# Server
PORT=8080
PROFILES_DIR=/opt/ocpctl/profiles
ADDONS_DIR=/opt/ocpctl/addons

# JWT - USE DIFFERENT SECRET FOR DEV
JWT_SECRET=GENERATE_NEW_SECRET_FOR_DEV  # openssl rand -base64 32
JWT_EXPIRY=24h

# Auth
AUTH_ENABLED=true
JWT_AUTH_ENABLED=true
IAM_AUTH_ENABLED=false  # Optional: enable IAM auth in dev if needed

# CORS - Allow local development
CORS_ORIGINS=http://localhost:3000,https://dev.ocpctl.mg.dog8code.com

# Environment marker
ENVIRONMENT=dev
AWS_REGION=us-east-1

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090
