# Dev Environment Configuration
# Copy this file to worker.env.dev and fill in the values

# Database - DEV ENVIRONMENT
# Option 1: Separate dev RDS instance
DATABASE_URL=postgresql://ocpctl_dev_user:CHANGE_ME@ocpctl-dev-db.xxx.rds.amazonaws.com:5432/ocpctl_dev?sslmode=require
# Option 2: Shared RDS with separate database
# DATABASE_URL=postgresql://ocpctl_dev_user:CHANGE_ME@ocpctl-db.xxx.rds.amazonaws.com:5432/ocpctl_dev?sslmode=require

# Worker
TMPDIR=/var/lib/ocpctl/tmp
PROFILES_DIR=/opt/ocpctl/profiles
WORKER_WORK_DIR=/var/lib/ocpctl/clusters
WORKER_HEALTH_PORT=8081

# S3 Configuration - DEV ENVIRONMENT
# Option 1: Separate dev buckets
S3_BUCKET_NAME=ocpctl-dev-binaries
# Option 2: Same bucket with dev/ prefix (requires code changes)
# S3_BUCKET_NAME=ocpctl-binaries
# S3_PREFIX=dev/

# OpenShift Pull Secret (same as production)
OPENSHIFT_PULL_SECRET='COPY_FROM_PRODUCTION'

# Environment marker
ENVIRONMENT=dev
AWS_REGION=us-east-1

# AWS Permanent Credentials (for Mint mode) - same as production
AWS_ACCESS_KEY_ID=COPY_FROM_PRODUCTION
AWS_SECRET_ACCESS_KEY=COPY_FROM_PRODUCTION

# IBM Cloud
IC_API_KEY=COPY_FROM_PRODUCTION
IBMCLOUD_API_KEY=COPY_FROM_PRODUCTION
IC_ACCOUNT_ID=COPY_FROM_PRODUCTION

# GCP Configuration
GOOGLE_APPLICATION_CREDENTIALS=/opt/ocpctl/gcp-credentials.json
GCP_PROJECT=COPY_FROM_PRODUCTION

# OCM Token (ROSA)
OCM_TOKEN=COPY_FROM_PRODUCTION

# Azure Authentication
AZURE_SUBSCRIPTION_ID=COPY_FROM_PRODUCTION
AZURE_TENANT_ID=COPY_FROM_PRODUCTION
AZURE_CLIENT_ID=COPY_FROM_PRODUCTION
AZURE_CLIENT_SECRET=COPY_FROM_PRODUCTION
AZURE_AUTH_LOCATION=/opt/ocpctl/.azure/osServicePrincipal.json
