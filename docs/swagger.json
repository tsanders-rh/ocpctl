                },
                "idempotency_key": {
                    "type": "string"
                },
                "name": {
                    "type": "string",
                    "maxLength": 63,
                    "minLength": 3
                },
                "offhours_opt_in": {
                    "type": "boolean"
                },
                "owner": {
                    "type": "string"
