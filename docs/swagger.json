                },
                "storage_config": {
                    "$ref": "#/definitions/github_com_tsanders-rh_ocpctl_pkg_types.StorageConfig"
                },
                "team": {
                    "type": "string"
                },
                "ttl_hours": {
                    "type": "integer"
                },
                "updated_at": {
                    "type": "string"
                },
                "version": {
                    "type": "string"
                },
                "work_days": {
                    "type": "integer"
                },
                "work_hours_enabled": {
                    "description": "NULL = use user default",
