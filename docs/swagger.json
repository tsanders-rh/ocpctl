                },
                "work_hours_end": {
                    "type": "string"
                },
                "work_hours_start": {
                    "type": "string"
                }
            }
        },
        "github_com_tsanders-rh_ocpctl_pkg_types.ClusterStatus": {
            "type": "string",
            "enum": [
                "PENDING",
                "CREATING",
                "READY",
                "HIBERNATING",
                "HIBERNATED",
                "RESUMING",
                "DESTROYING",
                "DESTROYED",
                "FAILED"
            ],
            "x-enum-varnames": [
                "ClusterStatusPending",
                "ClusterStatusCreating",
                "ClusterStatusReady",
                "ClusterStatusHibernating",
                "ClusterStatusHibernated",
                "ClusterStatusResuming",
                "ClusterStatusDestroying",
                "ClusterStatusDestroyed",
                "ClusterStatusFailed"
