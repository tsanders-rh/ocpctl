                "end_time": {
                    "description": "\"17:00\" format",
                    "type": "string"
                },
                "start_time": {
                    "description": "\"09:00\" format",
                    "type": "string"
                },
                "work_days": {
                    "description": "[\"Monday\", \"Tuesday\", ...]",
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
