                },
                "offhours_opt_in": {
                    "type": "boolean"
                },
                "owner": {
                    "description": "Email for display/metadata",
                    "type": "string"
                },
                "owner_id": {
                    "description": "Foreign key to users table",
                    "type": "string"
                },
                "platform": {
                    "$ref": "#/definitions/github_com_tsanders-rh_ocpctl_pkg_types.Platform"
